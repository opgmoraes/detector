@page
@model Detector.Pages.ErrorModel
@{
    ViewData["Title"] = "Erro";
}

<div class="text-center py-5">
    <i class="fa-solid fa-triangle-exclamation fa-4x text-warning mb-3"></i>
    <h1 class="display-4">Erro @Model.RequestId</h1>
    <p class="text-muted">Ocorreu um erro inesperado. Tente novamente.</p>
    <a asp-page="/Index" class="btn btn-dark mt-2">
        <i class="fa-solid fa-house me-1"></i>Voltar ao início
    </a>
</div>
