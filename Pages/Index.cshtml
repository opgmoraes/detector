@page
@model Detector.Pages.IndexModel
@{
    ViewData["Title"] = "Detector de Erros C#";
}

<!-- Hero -->
<div class="hero-section text-center mb-4">
    <div class="d-flex align-items-center justify-content-center gap-3 mb-2">
        <i class="fa-solid fa-bug fa-2x text-danger"></i>
        <h1 class="display-5 fw-bold mb-0">Detector de Erros em C#</h1>
    </div>
    <p class="text-muted lead">
        Cole um trecho de código C# abaixo e a IA dirá se há erros ou não.
    </p>
</div>

<div class="row g-4">
    <!-- Formulário principal -->
    <div class="col-lg-7">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white d-flex align-items-center gap-2">
                <i class="fa-solid fa-code"></i>
                <span class="fw-semibold">Código C# para Analisar</span>
            </div>
            <div class="card-body">
                <form method="post" id="formAnalise">
                    <div class="mb-3">
                        <label for="InputCode" class="form-label fw-semibold">
                            Cole seu código aqui:
                        </label>
                        <textarea asp-for="InputCode"
                                  class="form-control code-area"
                                  id="InputCode"
                                  rows="10"
                                  placeholder="Ex: int x = &quot;texto&quot;;&#10;Console.writeline(&quot;Olá&quot;)&#10;string nome = 42;"
                                  spellcheck="false"></textarea>
                        <div class="form-text">
                            <i class="fa-solid fa-circle-info me-1"></i>
                            Pode colar uma linha ou várias linhas de código C#.
                        </div>
                    </div>

                    <div class="d-flex gap-2 flex-wrap">
                        <button type="submit" class="btn btn-danger px-4" id="btnAnalisar">
                            <i class="fa-solid fa-magnifying-glass me-2"></i>Analisar Código
                        </button>
                        <button type="button" class="btn btn-outline-secondary" id="btnLimpar">
                            <i class="fa-solid fa-eraser me-1"></i>Limpar
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Exemplos rápidos -->
        <div class="card mt-3 border-0 shadow-sm">
            <div class="card-header bg-secondary text-white d-flex align-items-center gap-2">
                <i class="fa-solid fa-bolt"></i>
                <span class="fw-semibold">Exemplos Rápidos</span>
            </div>
            <div class="card-body">
                <div class="row g-2">
                    <div class="col-sm-6">
                        <button class="btn btn-outline-success btn-sm w-100 text-start exemplo-btn"
                                data-code='int x = 10;&#10;string nome = "João";&#10;Console.WriteLine(nome);'>
                            <i class="fa-solid fa-check-circle me-1"></i>Código Correto
                        </button>
                    </div>
                    <div class="col-sm-6">
                        <button class="btn btn-outline-danger btn-sm w-100 text-start exemplo-btn"
                                data-code='int x = "texto";&#10;Console.writeline("Olá")&#10;string nome = 42;'>
                            <i class="fa-solid fa-circle-xmark me-1"></i>Código com Erro
                        </button>
                    </div>
                    <div class="col-sm-6">
                        <button class="btn btn-outline-success btn-sm w-100 text-start exemplo-btn"
                                data-code='for (int i = 0; i < 10; i++) {&#10;    Console.WriteLine(i);&#10;}'>
                            <i class="fa-solid fa-check-circle me-1"></i>For Correto
                        </button>
                    </div>
                    <div class="col-sm-6">
                        <button class="btn btn-outline-danger btn-sm w-100 text-start exemplo-btn"
                                data-code='for (int i = 0; i < 10; i++ {&#10;    Console.writeline(i)&#10;}'>
                            <i class="fa-solid fa-circle-xmark me-1"></i>For com Erro
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Resultado -->
    <div class="col-lg-5">
        @if (Model.PredictionResult != null)
        {
            bool temErro = Model.PredictionResult.PredictedLabel;
            string alertClass = temErro ? "resultado-erro" : "resultado-ok";
            string iconClass = temErro ? "fa-circle-xmark text-danger" : "fa-circle-check text-success";
            string titulo = temErro ? "ERRO DETECTADO" : "CÓDIGO CORRETO";
            string subtitulo = temErro
                ? "A IA identificou possíveis problemas neste código."
                : "A IA não encontrou erros neste trecho.";
            float confianca = temErro ? Model.PredictionResult.Probability : (1f - Model.PredictionResult.Probability);
            int pct = (int)(confianca * 100);

            <div class="card border-0 shadow-sm @alertClass-card resultado-card">
                <div class="card-body text-center py-4">
                    <i class="fa-solid @iconClass fa-4x mb-3 d-block"></i>
                    <h2 class="fw-bold mb-1 @(temErro ? "text-danger" : "text-success")">@titulo</h2>
                    <p class="text-muted mb-3">@subtitulo</p>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <small class="text-muted">Confiança da IA</small>
                            <small class="fw-bold">@pct%</small>
                        </div>
                        <div class="progress" style="height:12px;">
                            <div class="progress-bar @(temErro ? "bg-danger" : "bg-success")"
                                 role="progressbar"
                                 style="width:@pct%"
                                 aria-valuenow="@pct"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                            </div>
                        </div>
                    </div>

                    <div class="info-box bg-light rounded p-2 mb-3 text-start">
                        <small class="text-muted d-block"><strong>Score bruto:</strong> @Model.PredictionResult.Score.ToString("F4")</small>
                        <small class="text-muted d-block"><strong>Probabilidade:</strong> @Model.PredictionResult.Probability.ToString("P2")</small>
                    </div>

                    <!-- Sistema de Feedback -->
                    <hr />
                    <p class="fw-semibold mb-2 small text-muted">A IA acertou? Deixe seu feedback:</p>
                    <form method="post" asp-page-handler="Feedback" id="formFeedback">
                        <input type="hidden" asp-for="InputCode" />
                        <input type="hidden" name="RespostaIA" value="@(temErro ? "TemErro" : "Correto")" />
                        <div class="d-flex gap-2 justify-content-center">
                            <button type="submit" name="TipoFeedback" value="1"
                                    class="btn btn-outline-success btn-sm px-3">
                                <i class="fa-solid fa-thumbs-up me-1"></i>Acertou
                            </button>
                            <button type="submit" name="TipoFeedback" value="2"
                                    class="btn btn-outline-danger btn-sm px-3">
                                <i class="fa-solid fa-thumbs-down me-1"></i>Errou
                            </button>
                            <button type="submit" name="TipoFeedback" value="3"
                                    class="btn btn-outline-secondary btn-sm px-3">
                                <i class="fa-solid fa-minus me-1"></i>Neutro
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        }
        else
        {
            <!-- Estado vazio -->
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center text-center py-5">
                    <i class="fa-solid fa-robot fa-4x text-secondary mb-3 opacity-50"></i>
                    <h5 class="text-muted">Aguardando análise</h5>
                    <p class="text-muted small">Cole um trecho de código e clique em <strong>Analisar</strong>.</p>
                </div>
            </div>
        }

        @if (Model.FeedbackEnviado)
        {
            <div class="alert alert-success mt-3 d-flex align-items-center gap-2" role="alert">
                <i class="fa-solid fa-circle-check"></i>
                <span>Feedback registrado com sucesso! Obrigado.</span>
            </div>
        }
    </div>
</div>

@section Scripts {
<script>
    // Botão limpar
    document.getElementById('btnLimpar').addEventListener('click', function () {
        document.getElementById('InputCode').value = '';
        document.getElementById('InputCode').focus();
    });

    // Exemplos rápidos
    document.querySelectorAll('.exemplo-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var code = this.getAttribute('data-code')
                .replace(/&#10;/g, '\n')
                .replace(/&quot;/g, '"');
            document.getElementById('InputCode').value = code;
            document.getElementById('InputCode').focus();
        });
    });

    // Loading no botão analisar
    document.getElementById('formAnalise').addEventListener('submit', function () {
        var btn = document.getElementById('btnAnalisar');
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Analisando...';
        btn.disabled = true;
    });
</script>
}
